{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "height": 34,
    "reload_style_on_change": true,
    "modules-left": [ "custom/logo", "hyprland/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": [ "tray", "memory", "network", "wireplumber", "battery", "custom/power" ],
    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-right": "fullscreen",
        "icon-theme": "WhiteSur",
        "icon-size": 25,
        "tooltip-format": "{title}"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "persistent-only": true,
        "format-icons": {
            "default": "Όσ▒",
            "1": "ΌψΙ ",
            "2": "ΎΤΙ ",
            "3": "ΎΗ╝ ",
            "4": "Όφμ ",
            "5": "ΌηΧ ",
            "urgent": "≤▒Υ╗"
        },
        "persistent_workspaces": {
          "*": 5
        }
    },
    "memory": {
        "interval": 5,
        "format": "≤░Ξδ {}%",
        "max-length": 10
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "{calendar}",
        "format-alt": "Ός░  {:%a, %d %b %Y}",
        "format": "ΎΡ║  {:%I:%M %p}"
    },
    "network": {
        "format-wifi" : "{icon}",
        "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
        "format-ethernet": "≤░ΑΓ",
	"format-alt" : "≤▒δΘ",
        "format-disconnected" : "≤░Ψς",
	"tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
	"tooltip-format-disconnected": "Disconnected",
	"on-click": "~/.config/rofi/wifi/wifi.sh &",
        "on-click-right": "~/.config/rofi/wifi/wifinew.sh &",
	"interval": 5,
	"nospacing": 1
    },
    "wireplumber": {
        "format": "{icon}",
        "format-bluetooth": "≤░Γ░",
        "nospacing": 1,
        "tooltip-format": "Volume : {volume}%",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["≤░ΨΑ","≤░Χ╛","ΎΑρ"]
        },
        "on-click": "pamixer -t",
        "scroll-step": 1
    },
    "custom/logo": {
        "format": " ΎΝΥ ",
        "tooltip": false,
        "on-click": "~/.config/rofi/launchers/misc/launcher.sh &"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": {
            "charging": [
                "≤░λε",
                "≤░ΓΗ",
                "≤░ΓΘ",
                "≤░ΓΙ",
                "≤░λζ",
                "≤░ΓΚ",
                "≤░λη",
                "≤░ΓΛ",
                "≤░ΓΜ",
                "≤░ΓΖ"
            ],
            "default": [
                "≤░Β║",
                "≤░Β╗",
                "≤░Β╝",
                "≤░Β╜",
                "≤░Β╛",
                "≤░Β┐",
                "≤░ΓΑ",
                "≤░ΓΒ",
                "≤░ΓΓ",
                "≤░Β╣"
            ]
        },
        "format-full": "Charged ΎΔπ",
        "interval": 5,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": false
    },
    "custom/power": {
        "format": "≤░νΗ",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/type-2/powermenu.sh &"
    }
}
